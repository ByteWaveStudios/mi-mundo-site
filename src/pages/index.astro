---
import { Image } from "astro:assets";

import Layout from "../layouts/Layout.astro";
import AppScreenshot from "../assets/app-screenshot.png";
import Logo from "../assets/logo.png";
import QRIos from "../assets/qr-code-ios-app-store.svg";
import QRAndroid from "../assets/qr-code-android-play-store.svg";
---

<Layout>
  <div
    id="get-app-popover"
    popover="auto"
    class="get-app-popover fixed left-1/2 top-1/2 w-[min(95vw,44rem)] -translate-x-1/2 -translate-y-1/2 rounded-2xl border border-white/10 bg-slate-900/95 p-4 shadow-2xl backdrop-blur-xl backdrop:bg-black/50"
  >
    <div class="mb-5 flex items-center justify-between">
      <h3 class="text-xl font-semibold text-white">Get the App</h3>
      <button
        type="button"
        popovertarget="get-app-popover"
        popovertargetaction="hide"
        class="rounded-full p-1.5 text-slate-400 transition hover:bg-white/10 hover:text-white"
        aria-label="Close"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="h-5 w-5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <p class="mb-8 text-sm text-slate-400">Scan to download on your device</p>
    <div class="flex justify-center gap-12 flex-wrap">
      <a
        href="https://apps.apple.com/ca/app/mi-mundo/id6752587157"
        class="flex min-w-0 flex-col items-center rounded-xl bg-white/5 px-8 py-6 transition hover:bg-white/10"
      >
        <Image
          src={QRIos}
          alt="QR code for App Store"
          class="mb-5 h-48 w-48 rounded-lg bg-white object-contain"
          width={192}
          height={192}
        />
        <div class="flex items-center gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="h-5 w-5 shrink-0 text-white"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
            ></path>
          </svg>
          <span class="text-sm font-medium text-white">App Store</span>
        </div>
      </a>
      <a
        href="https://play.google.com/store/apps/details?id=com.bytewavestudioscanada.mimundo"
        class="flex min-w-0 flex-col items-center rounded-xl bg-white/5 px-8 py-6 transition hover:bg-white/10"
      >
        <Image
          src={QRAndroid}
          alt="QR code for Google Play"
          class="mb-5 h-48 w-48 rounded-lg bg-white object-contain"
          width={192}
          height={192}
        />
        <div class="flex items-center gap-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="h-5 w-5 shrink-0 text-white"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L12.001 12l5.697-5.491zM5.864 2.658L16.802 8.99l-2.302 2.302-8.636-8.634z"
            ></path>
          </svg>
          <span class="text-sm font-medium text-white">Google Play</span>
        </div>
      </a>
    </div>
  </div>

  <section class="hero-gradient pt-32 pb-20 px-6">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-4">
      <div class="lg:w-1/2 space-y-8 text-center md:text-left">
        <h1 class="text-5xl md:text-7xl font-bold text-white leading-tight">
          Showcase Your <span
            class="text-transparent bg-clip-text bg-linear-to-r from-indigo-400 to-cyan-400"
            >Business</span
          > to the World.
        </h1>
        <p class="text-lg text-slate-400 max-w-lg mx-auto md:mx-0">
          Create, manage, and show off your small business with ease. Mi Mundo
          gives you a beautiful, professional business page that captures the
          true spirit of what you do.
        </p>
        <div
          id="download"
          class="flex flex-col sm:flex-row justify-center md:justify-start space-y-4 sm:space-y-0 sm:space-x-4 pt-4"
        >
          <a
            href="https://apps.apple.com/ca/app/mi-mundo/id6752587157"
            class="flex items-center justify-center gap-2 bg-white text-black px-8 py-3 rounded-xl font-bold hover:bg-slate-200 transition min-w-8 whitespace-nowrap shrink-0"
          >
            <!-- Apple App Store icon -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              class="w-8 h-8 shrink-0"
              aria-hidden="true"
              fill="currentColor"
            >
              <path
                d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
              ></path>
            </svg>
            <span>App Store</span>
          </a>
          <a
            href="https://play.google.com/store/apps/details?id=com.bytewavestudioscanada.mimundo"
            class="flex items-center justify-center gap-2 border border-white/60 px-8 py-3 rounded-xl font-bold hover:bg-white/10 transition text-white whitespace-nowrap shrink-0"
          >
            <!-- Google Play icon -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              class="w-8 h-8 shrink-0"
              aria-hidden="true"
            >
              <path
                fill="currentColor"
                d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L12.001 12l5.697-5.491zM5.864 2.658L16.802 8.99l-2.302 2.302-8.636-8.634z"
              ></path>
            </svg>
            <span>Google Play</span>
          </a>
        </div>
      </div>
      <div class="md:w-1/2 mt-16 md:mt-0 relative flex justify-center">
        <div
          class="relative w-64 h-[500px] bg-slate-800 rounded-[3rem] border-8 border-slate-700 shadow-2xl overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-linear-to-b from-indigo-900/40 to-slate-900 flex items-center justify-center text-slate-500 text-sm"
          >
            <Image
              src={AppScreenshot}
              alt="App Screenshot"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
        <div
          class="absolute -z-10 w-72 h-72 bg-indigo-600/20 blur-[100px] top-10"
        >
        </div>
      </div>
    </div>
  </section>

  <section id="features" class="py-24 px-6 bg-slate-950">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-white">Why Mi Mundo?</h2>
        <p class="text-slate-400 mt-4">
          Powerful tools designed for the modern entrepreneur.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div
          class="p-8 rounded-2xl border border-white/5 bg-white/5 hover:bg-white/10 transition group"
        >
          <div
            class="w-12 h-12 bg-indigo-500/20 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition text-indigo-400"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-6 h-6"
              aria-hidden="true"
            >
              <path d="M15 4V2m0 2v2m4-4v2m0 2V4M5 20l4-8 4 4 6-12 2 8"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Beautiful Pages</h3>
          <p class="text-slate-400">
            Transform your business info into an elegant profile that attracts
            customers instantly.
          </p>
        </div>
        <div
          class="p-8 rounded-2xl border border-white/5 bg-white/5 hover:bg-white/10 transition group"
        >
          <div
            class="w-12 h-12 bg-cyan-500/20 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition text-cyan-400"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-6 h-6"
              aria-hidden="true"
            >
              <path d="M9 11l3 3L22 4"></path>
              <path
                d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Easy Management</h3>
          <p class="text-slate-400">
            Update your details, photos, and offerings on the fly with our
            intuitive dashboard.
          </p>
        </div>
        <div
          class="p-8 rounded-2xl border border-white/5 bg-white/5 hover:bg-white/10 transition group"
        >
          <div
            class="w-12 h-12 bg-purple-500/20 rounded-lg flex items-center justify-center mb-6 group-hover:scale-110 transition text-purple-400"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-6 h-6"
              aria-hidden="true"
            >
              <circle cx="18" cy="5" r="3"></circle>
              <circle cx="6" cy="12" r="3"></circle>
              <circle cx="18" cy="19" r="3"></circle>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">Instant Visibility</h3>
          <p class="text-slate-400">
            Get your business in front of local users and interested explorers
            immediately.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
