---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Logo from "../assets/logo.png";

const emailAddress = "info@bytewavestudios.ca";
---

<Layout title="Privacy Policy | Mi Mundo">
  <nav class="fixed w-full z-50 glass border-b border-white/10">
    <div class="w-full px-6 py-4 flex justify-between items-center">
      <a href="/" class="flex items-center space-x-2">
        <Image src={Logo} alt="Logo" class="w-12 h-12" />
        <span class="text-xl font-semibold tracking-tight text-white"
          >Mi Mundo</span
        >
      </a>
      <a
        href="/#download"
        class="bg-indigo-600 hover:bg-indigo-500 text-white px-5 py-2 rounded-full text-sm font-semibold transition shadow-lg shadow-indigo-500/20"
        >Get App</a
      >
    </div>
  </nav>

  <section class="hero-gradient pt-32 pb-20 px-6 min-h-screen">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-8">
        Privacy Policy
      </h1>
      <p class="text-slate-400 mb-8">
        Effective Date: July 8th, 2025<br />
        App Maintained by ByteWave Studios Inc.
      </p>

      <div
        class="prose prose-invert prose-slate max-w-none space-y-8 text-slate-300"
      >
        <section>
          <h2 class="text-xl font-bold text-white mt-10 mb-4">Introduction</h2>
          <p class="text-slate-400">
            Welcome to Mi Mundo, a mobile application designed to help you
            connect with the world. At Mi Mundo, we are committed to protecting
            your privacy and ensuring the security of the personal information
            you provide. This Privacy Policy explains how we collect, use, and
            protect your information when you use our mobile app.
          </p>
          <p class="text-slate-400">
            By downloading, installing, and using Mi Mundo, you agree to the
            terms and practices described in this Privacy Policy.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-white mt-10 mb-4">
            Information We Collect
          </h2>
          <p class="text-slate-400 mb-4">
            We collect the following basic user information for account
            registration purposes:
          </p>
          <ul class="list-disc pl-6 space-y-2 text-slate-400">
            <li>
              <strong class="text-slate-300">Full Name:</strong> We collect your first
              and last name as it is important for account identification.
            </li>
            <li>
              <strong class="text-slate-300">Username:</strong> You choose a unique
              username when registering your account.
            </li>
            <li>
              <strong class="text-slate-300">Email Address:</strong> We collect your
              email address to send you important account-related information and
              for account recovery purposes.
            </li>
            <li>
              <strong class="text-slate-300">Password:</strong> You create a password
              for your Mi Mundo account, which is securely encrypted and stored to
              ensure your account's security.
            </li>
          </ul>
        </section>

        <section>
          <h2 class="text-xl font-bold text-white mt-10 mb-4">
            How We Use Your Information
          </h2>
          <p class="text-slate-400 mb-4">
            We use the collected information for the following purposes:
          </p>
          <ul class="list-disc pl-6 space-y-2 text-slate-400">
            <li>
              <strong class="text-slate-300">Account Management:</strong> Your username
              and email address are used for account creation, login, and account
              recovery.
            </li>
            <li>
              <strong class="text-slate-300">Communication:</strong> We may use your
              email address to send you important notifications and updates related
              to your Mi Mundo account.
            </li>
            <li>
              <strong class="text-slate-300">Improving Our Services:</strong> We may
              use aggregated, non-identifiable data to analyze user behavior and preferences,
              helping us enhance and optimize the app's features and functionality.
            </li>
          </ul>
        </section>

        <section>
          <h2 class="text-xl font-bold text-white mt-10 mb-4">Data Security</h2>
          <p class="text-slate-400">
            We take the security of your data seriously and employ reasonable
            and industry-standard security measures to protect your personal
            information from unauthorized access, disclosure, alteration, or
            destruction. Your password is securely encrypted, and we use secure
            transmission protocols to protect data during transit.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-white mt-10 mb-4">
            Third-Party Services
          </h2>
          <p class="text-slate-400">
            Mi Mundo may integrate third-party services, such as social media
            platforms, for user convenience. Please be aware that these
            third-party services have their own privacy policies and data
            practices, which are beyond our control. We encourage you to review
            their policies and settings when using such services.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-white mt-10 mb-4">
            Children's Privacy
          </h2>
          <p class="text-slate-400">
            Mi Mundo is not intended for users under the age of 13. We do not
            knowingly collect information from children under 13. If you believe
            that we have inadvertently collected data from a child under 13,
            please contact us, and we will take the necessary steps to remove
            the information.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-white mt-10 mb-4">
            Changes to this Privacy Policy
          </h2>
          <p class="text-slate-400">
            We may update this Privacy Policy to reflect changes in our
            information practices. You will be notified of any significant
            updates through the app, and we recommend checking this policy
            periodically for any changes. Your continued use of Mi Mundo after
            any updates constitutes acceptance of the revised policy.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-white mt-10 mb-4">
            Request Your Data to Be Deleted
          </h2>
          <p class="text-slate-400">
            If you want your data to be removed from our servers, please contact
            us at <a
              href={`mailto:${emailAddress}`}
              class="text-indigo-400 hover:text-indigo-300 underline"
              >{emailAddress}</a
            > and provide us with your account username.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold text-white mt-10 mb-4">Contact Us</h2>
          <p class="text-slate-400">
            If you have any questions or concerns about this Privacy Policy or
            the data practices of Mi Mundo, please contact us at <a
              href={`mailto:${emailAddress}`}
              class="text-indigo-400 hover:text-indigo-300 underline"
              >{emailAddress}</a
            >.
          </p>
          <p class="text-slate-400 mt-4">
            Thank you for trusting Mi Mundo with your information. We are
            committed to safeguarding your privacy and providing you with a safe
            and enjoyable user experience.
          </p>
        </section>
      </div>

      <p class="mt-12 text-slate-500 text-sm">Effective Date: July 8th, 2025</p>
    </div>
  </section>

  <footer class="py-12 border-t border-white/10 px-6">
    <div
      class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center text-slate-500 text-sm"
    >
      <div class="mb-4 md:mb-0">
        &copy; 2026 ByteWave Studios Inc. All rights reserved.
      </div>
      <div class="flex space-x-6">
        <a href="/privacy" class="hover:text-white transition">Privacy Policy</a
        >
        <a href="/contact" class="hover:text-white transition">Contact</a>
        <a href="/" class="hover:text-white transition">Home</a>
      </div>
    </div>
  </footer>
</Layout>
