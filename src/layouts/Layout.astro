---
import "../styles/global.css";

type Props = {
  title?: string;
};

const { title = "Mi Mundo | Showcase Your Small Business" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body
    class="bg-slate-950 text-slate-200 font-sans selection:bg-indigo-500/30"
  >
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
